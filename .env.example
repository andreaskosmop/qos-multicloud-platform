# ── Βάση Δεδομένων (PostgreSQL) ──────────────────────────────────
DB_USERNAME=cloudplatform_user
DB_PASSWORD=changeme_strong_password

# ── JWT (HS256 signing key — §4.4.1) ─────────────────────────────
# Ελάχιστο 32 χαρακτήρες για HS256
JWT_SECRET=changeme_min_32_characters_long_secret_key

# ── SMTP (NotificationService — email ειδοποιήσεις/reset password) ──
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password

# ── AWS Credentials (για Terraform EKS provisioning) ─────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1

# ── Azure Credentials (για Terraform AKS provisioning) ───────────
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

# ── Google OAuth2 (προαιρετική απαίτηση MFA-OPT01) ───────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
